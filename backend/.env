# Database
DATABASE_URL="postgresql+asyncpg://app_user:dev_password@localhost:5432/activia_trace"

# Security
SECRET_KEY="dev-secret-key-at-least-32-chars-long-for-active-trace"
ENCRYPTION_KEY="dev-encryption-key-32-chars-!!!!"

# Token configuration
ACCESS_TOKEN_EXPIRE_MINUTES=15

# OpenTelemetry (optional — leave empty to disable)
OTEL_SERVICE_NAME="activia-trace"
OTEL_EXPORTER_OTLP_ENDPOINT=""
