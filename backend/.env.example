# Database
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/activia_trace"

# Security
SECRET_KEY="change-me-to-a-random-string-at-least-32-chars-long"
ENCRYPTION_KEY="change-me-32-chars-exact!"

# Token configuration
ACCESS_TOKEN_EXPIRE_MINUTES=15

# OpenTelemetry (optional — leave empty to disable)
OTEL_SERVICE_NAME="activia-trace"
OTEL_EXPORTER_OTLP_ENDPOINT=""

# Test database (used by pytest)
DATABASE_URL_TEST="postgresql+asyncpg://user:password@localhost:5432/activia_trace_test"
